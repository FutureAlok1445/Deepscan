function useMock() { return import.meta.env.MODE === 'development'; }

export async function analyzeFile(file, language = 'hi') {
  try {
    const formData = new FormData();
    formData.append('file', file);
    formData.append('language_preference', language);
    const res = await api.post('/analyze', formData, { headers: { 'Content-Type': 'multipart/form-data' } });
    return res.data;
  } catch (err) {
    if (useMock()) return { ...MOCK_RESULT, id: 'mock-' + Date.now() };
    throw err;
  }
}

export async function analyzeUrl(url, language = 'hi') {
  try {
    const res = await api.post('/analyze/url', { url, language_preference: language });
    return res.data;
  } catch (err) {
    if (useMock()) return { ...MOCK_RESULT, id: 'mock-url-' + Date.now() };
    throw err;
  }
}

export async function getResult(id) {
  try {
    const res = await api.get(`/result/${id}`);
    return res.data;
  } catch (err) {
    if (useMock()) return { ...MOCK_RESULT, id };
    throw err;
  }
}

export async function downloadReport(id) {
  try {
    const res = await api.get(`/report/${id}`, { responseType: 'blob' });
    const url = window.URL.createObjectURL(new Blob([res.data]));
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `DeepScan_Report_${id}.pdf`);
    document.body.appendChild(link);
    link.click();
    link.remove();
    window.URL.revokeObjectURL(url);
  } catch (err) {
    if (useMock()) { console.log('Mock: PDF download for', id); return; }
    throw err;
  }
}

export async function getHistory() {
  try { return (await api.get('/history')).data; }
  catch (err) { if (useMock()) return MOCK_HISTORY; throw err; }
}

export async function getCommunityAlerts() {
  try { return (await api.get('/community')).data; }
  catch (err) { if (useMock()) return MOCK_COMMUNITY; throw err; }
}

export async function submitFeedback(id, isCorrect, comment = '') {
  try { return (await api.post('/feedback', { analysis_id: id, is_correct: isCorrect, comment })).data; }
  catch (err) { if (useMock()) return { success: true }; throw err; }
}
